          "value": 30
        },
        {
          "id": "knob_2",
          "x": 357,
          "y": 193,
          "width": 80,
          "height": 80,
          "type": "knob",
          "min": 0,
          "max": 100,
          "value": 50,
          "startAngle": 135,
          "endAngle": 45
        }
      ]
    },
    {
      "id": "page_settings",
      "name": "Settings",
      "components": [
        {
          "id": "ta_2",
          "x": 230,
          "y": 204,
          "width": 160,
          "height": 72,
          "type": "textarea",
          "text": ""
        },
        {
          "id": "sw_2",
          "x": 341,
          "y": 137,
          "width": 52,
          "height": 28,
          "type": "switch",
          "checked": false
        },
        {
          "id": "btn_2",
          "x": 681,
          "y": 421,
          "width": 88,
          "height": 36,
          "type": "button",
          "label": "Home",
          "hidden": false,
          "events": [
            {
              "trigger": "clicked",
              "actions": [
                {
                  "type": "navigate",
