{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://embeddedflow/embf.schema.json",
  "title": "EmbeddedFlow Project",
  "description": "EmbeddedFlow .embf project file schema",
  "type": "object",
  "required": ["version", "project", "display", "pages"],
  "additionalProperties": false,
  "description": "EmbeddedFlow compile-time IR. Single source of truth for UI, model, state, actions, and protocol bindings.",
  "properties": {
    "version": {
      "type": "string",
      "enum": ["1.0"],
      "description": "Schema version"
    },
    "project": {
      "type": "object",
      "required": ["name", "lvglVersion"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "lvglVersion": {
          "type": "string",
          "enum": ["8.4.0", "9.2.2", "9.3.0", "9.4.0", "9.5.0"]
        },
        "description": { "type": "string" },
        "outputPath": {
          "type": "string",
          "minLength": 1,
          "description": "Output folder for generated C code (relative to the .embf file or absolute). Overrides the embeddedflow.outputDirectory workspace setting when set."
        },
        "lvglInclude": {
          "type": "string",
          "enum": ["lvgl.h", "lvgl/lvgl.h"],
          "description": "LVGL header include path emitted in generated ui*.h files."
        },
        "firmwarePath": {
          "type": "string",
          "description": "Path to firmware project root containing compile_commands.json. Used by EmbeddedFlow to spawn a dedicated clangd instance for symbol discovery (Phase 2+). Relative to the .embf file or absolute."
        },
        "stringsPath": {
          "type": "string",
          "pattern": ".*\\.res$",
          "description": "Path to i18n string resource file (default: i18n/strings.res). Must use .res extension. Edited via table UI in extension; widgets reference keys. See docs/REQUIREMENTS.md § Internationalization."
        }
      }
    },
    "display": {
      "type": "object",
      "required": ["width", "height", "bitDepth", "colorFormat", "orientation", "direction"],
      "additionalProperties": false,
      "properties": {
        "width": { "type": "integer", "minimum": 1, "maximum": 4096 },
        "height": { "type": "integer", "minimum": 1, "maximum": 4096 },
        "bitDepth": { "type": "integer", "enum": [16, 24, 32] },
        "colorFormat": {
          "type": "string",
          "enum": ["RGB565", "RGB888", "ARGB8888", "L8", "AL88"]
        },
        "orientation": {
          "type": "string",
          "enum": ["portrait", "landscape", "portrait_flipped", "landscape_flipped"]
        },
        "direction": { "type": "string", "enum": ["ltr", "rtl"] },
        "dpi": { "type": "integer", "minimum": 1 },
        "round": {
          "type": "boolean",
          "description": "When true, EmbeddedFlow preview clips the panel to a circle (diameter = min(width, height)). Firmware must still drive a round display in native code."
        }
      }
    },
    "theme": {
      "type": "object",
      "required": ["dark"],
      "additionalProperties": false,
      "properties": {
        "dark": { "type": "boolean" },
        "primaryColor": { "type": "string" },
        "secondaryColor": { "type": "string" }
      }
    },
    "fonts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "size"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "size": { "type": "integer", "minimum": 4 },
          "source": { "type": "string" }
        }
      }
    },
    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/page" }
    },
    "componentLibrary": {
      "type": "array",
      "description": "Reusable grouped widgets (saved container/panel subtrees)",
      "items": { "$ref": "#/definitions/componentLibraryEntry" }
    },
    "model": {
      "type": "object",
      "description": "Application data model. Properties are IR metadata in Phase 1 (preview mocks only). Backed by firmware C symbols in Phase 2+ via clangd symbol discovery.",
      "additionalProperties": false,
      "properties": {
        "properties": {
          "type": "array",
          "description": "Named application properties. Phase 1: metadata + preview defaults. Phase 2+: bound to firmware C symbols.",
          "items": {
            "type": "object",
            "required": ["id", "type"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "minLength": 1, "description": "Unique property identifier. Used in bindings, actions, and derived expressions." },
              "type": { "type": "string", "enum": ["float", "int", "bool", "string"], "description": "C-compatible data type." },
              "default": { "description": "Default value used for preview mocks and generated init values." },
              "min": { "type": "number", "description": "Minimum value (float/int only). Used for range validation and transforms." },
              "max": { "type": "number", "description": "Maximum value (float/int only). Used for range validation and transforms." },
              "direction": {
                "type": "string",
                "enum": ["push", "pull"],
                "description": "Binding direction. push = firmware calls generated setter (ui_set_<id>). pull = generated code reads extern symbol via ui_bindings_apply(). Compiler determines codegen strategy from this field."
              },
              "symbol": {
                "type": "string",
                "description": "Phase 2+: C symbol path discovered via clangd (e.g. 'app_data.temp_c'). Must exist in firmwarePath compile_commands.json."
              }
            }
          }
        },
        "derived": {
          "type": "array",
          "description": "Derived boolean conditions computed from properties. Generated as inline or cached C functions. No runtime storage. Separate from FSM states.",
          "items": {
            "type": "object",
            "required": ["id", "expression"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "minLength": 1, "description": "Unique identifier. Referenced in visibility rules and action guards." },
              "expression": { "type": "string", "description": "C expression string evaluated over property ids (e.g. 'temp_c > 80.0'). No side effects allowed." },
              "cached": { "type": "boolean", "default": false, "description": "If true, generate a static variable updated in update_derived_states(). If false, generate an inline function." }
            }
          }
        }
      }
    },
    "state": {
      "type": "object",
      "description": "Application FSM (Finite State Machine). Controls coarse application modes. Strictly separate from derived state in model.derived.",
      "additionalProperties": false,
      "properties": {
        "fsm": {
          "type": "object",
          "description": "Single application FSM. Generates app_state_t enum and set_state() transition function in ui_fsm.c.",
          "required": ["states", "initial"],
          "additionalProperties": false,
          "properties": {
            "states": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 },
              "description": "Named state identifiers (e.g. ['idle','connecting','connected','alarm']). Generated as STATE_<ID> enum values."
            },
            "initial": { "type": "string", "description": "Initial state id. Must exist in states[]." }
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "description": "Compiled action sequences. Each entry declares a trigger and a typed instruction sequence. Compiler flattens sequence to one deterministic C function per trigger. No runtime interpreter.",
      "items": {
        "type": "object",
        "required": ["id", "trigger", "sequence"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1, "description": "Unique action identifier. Generated function name: action_<id>()." },
          "trigger": { "type": "string", "description": "Trigger descriptor. Format: '<widgetId>.<event>', 'state:<stateId>.enter', 'state:<stateId>.exit', 'timer:every:<ms>', 'timer:after:<ms>', 'extern:<name>'." },
          "sequence": {
            "type": "array",
            "minItems": 1,
            "description": "Ordered list of typed instruction nodes. Compiled to sequential C statements.",
            "items": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["navigate", "set_property", "set_state", "call_function", "publish"],
                  "description": "Instruction type. navigate: static LVGL screen load. set_property: assign value to property. set_state: FSM transition. call_function: call validated C symbol. publish: abstract protocol publish (Phase 4)."
                },
                "target": { "type": "string", "description": "For navigate: page id. For set_property: property id. For set_state: state id." },
                "value": { "type": "string", "description": "For set_property: literal value or source expression (e.g. 'slider_brightness.value')." },
                "name": { "type": "string", "description": "For call_function: C function symbol name. Must exist in clangd symbol graph (Phase 2+)." },
                "topic": { "type": "string", "description": "For publish: protocol topic string." },
                "animation": { "type": "string", "description": "For navigate: LVGL screen load animation (e.g. 'move_left', 'fade', 'none')." },
                "duration": { "type": "integer", "minimum": 0, "description": "For navigate: animation duration in milliseconds." }
              }
            }
          }
        }
      }
    },
    "protocol": {
      "type": "array",
      "description": "Phase 4: abstract protocol binding declarations. EmbeddedFlow generates embf_protocol.h interface only. Actual transport implementation is provided by firmware or optional platform adapters. No MQTT/BLE/Modbus code is generated in core output.",
      "items": {
        "type": "object",
        "required": ["id", "direction", "topic", "propertyId"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "direction": { "type": "string", "enum": ["in", "out"], "description": "in = incoming message updates property. out = property change publishes to topic." },
          "topic": { "type": "string", "description": "Protocol topic, characteristic id, or register address. Protocol-agnostic string." },
          "propertyId": { "type": "string", "description": "Property id from model.properties[] to bind to." }
        }
      }
    }
  },
  "definitions": {
    "componentLibraryEntry": {
      "type": "object",
      "required": ["id", "name", "width", "height", "root"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "width": { "type": "number", "minimum": 1 },
        "height": { "type": "number", "minimum": 1 },
        "root": {
          "oneOf": [
            { "$ref": "#/definitions/containerComponent" },
            { "$ref": "#/definitions/panelComponent" }
          ]
        }
      }
    },
    "page": {
      "type": "object",
      "required": ["id", "name", "components"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "backgroundColor": { "type": "string" },
        "scrollX": { "type": "boolean", "description": "Enable horizontal scrolling on the page screen" },
        "scrollY": { "type": "boolean", "description": "Enable vertical scrolling on the page screen" },
        "components": {
          "type": "array",
          "items": { "$ref": "#/definitions/component" }
        },
        "swipes": {
          "type": "array",
          "description": "Swipe on this page's screen to navigate (LVGL LV_EVENT_GESTURE)",
          "items": { "$ref": "#/definitions/pageSwipe" }
        }
      }
    },
    "pageSwipe": {
      "type": "object",
      "required": ["direction", "target"],
      "additionalProperties": false,
      "properties": {
        "direction": {
          "type": "string",
          "enum": ["left", "right", "top", "bottom"],
          "description": "Finger swipe direction on the screen"
        },
        "target": {
          "type": "string",
          "minLength": 1,
          "description": "Page ID to load"
        },
        "anim": {
          "type": "string",
          "enum": [
            "none",
            "move_left",
            "move_right",
            "move_top",
            "move_bottom",
            "over_left",
            "over_right",
            "over_top",
            "over_bottom",
            "fade_in",
            "fade_out",
            "out_left",
            "out_right",
            "out_top",
            "out_bottom"
          ]
        },
        "time": { "type": "integer", "minimum": 0 },
        "delay": { "type": "integer", "minimum": 0 },
        "autoDel": { "type": "boolean" }
      }
    },
    "styleProps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bgColor": { "type": "string" },
        "indicatorColor": {
          "type": "string",
          "description": "Bar / slider / switch indicator fill (LV_PART_INDICATOR)"
        },
        "bgOpacity": { "type": "number", "minimum": 0, "maximum": 255 },
        "textColor": { "type": "string" },
        "borderColor": { "type": "string" },
        "borderWidth": { "type": "integer", "minimum": 0 },
        "borderRadius": { "type": "integer", "minimum": 0 },
        "padding": {
          "oneOf": [
            { "type": "integer" },
            { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 4 }
          ]
        },
        "fontSize": { "type": "integer", "minimum": 4 },
        "fontFamily": { "type": "string" },
        "align": { "type": "string", "enum": ["left", "center", "right"] }
      }
    },
    "action": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "target"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "navigate" },
            "target": {
              "type": "string",
              "minLength": 1,
              "description": "Page ID to load"
            },
            "anim": {
              "type": "string",
              "enum": [
                "none",
                "move_left",
                "move_right",
                "move_top",
                "move_bottom",
                "over_left",
                "over_right",
                "over_top",
                "over_bottom",
                "fade_in",
                "fade_out",
                "out_left",
                "out_right",
                "out_top",
                "out_bottom"
              ],
              "description": "Screen load animation (omit or none for instant load)"
            },
            "time": {
              "type": "integer",
              "minimum": 0,
              "description": "Animation duration in ms (default 300)"
            },
            "delay": {
              "type": "integer",
              "minimum": 0,
              "description": "Delay before animation in ms (default 0)"
            },
            "autoDel": {
              "type": "boolean",
              "description": "Delete previous screen when animation finishes"
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "route"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "nav_push" },
            "route": { "type": "string", "minLength": 1 },
            "anim": { "type": "string" },
            "time": { "type": "integer", "minimum": 0 },
            "delay": { "type": "integer", "minimum": 0 },
            "autoDel": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "required": ["type"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "nav_pop" },
            "anim": { "type": "string" },
            "time": { "type": "integer", "minimum": 0 },
            "delay": { "type": "integer", "minimum": 0 }
          }
        },
        {
          "type": "object",
          "required": ["type", "route"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "nav_replace" },
            "route": { "type": "string", "minLength": 1 },
            "anim": { "type": "string" },
            "time": { "type": "integer", "minimum": 0 },
            "delay": { "type": "integer", "minimum": 0 },
            "autoDel": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "required": ["type", "route"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "nav_reset" },
            "route": { "type": "string", "minLength": 1 },
            "anim": { "type": "string" },
            "time": { "type": "integer", "minimum": 0 },
            "delay": { "type": "integer", "minimum": 0 },
            "autoDel": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "required": ["type", "target", "text"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "set_text" },
            "target": {
              "type": "string",
              "minLength": 1,
              "description": "Component ID of the label"
            },
            "text": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "object",
                  "required": ["ref"],
                  "properties": {
                    "ref": {
                      "type": "string",
                      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
                    }
                  },
                  "additionalProperties": false
                }
              ]
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "target", "value"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "set_value" },
            "target": {
              "type": "string",
              "minLength": 1,
              "description": "Component ID of slider / bar / arc"
            },
            "value": { "type": "number" }
          }
        },
        {
          "type": "object",
          "required": ["type", "target", "checked"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "set_checked" },
            "target": {
              "type": "string",
              "minLength": 1,
              "description": "Component ID of switch / checkbox"
            },
            "checked": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "required": ["type", "target", "hidden"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "set_hidden" },
            "target": {
              "type": "string",
              "minLength": 1,
              "description": "Component ID"
            },
            "hidden": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "required": ["type"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "set_theme" },
            "dark": {
              "type": "boolean",
              "description": "Force light/dark. Omit on value_changed from a switch/checkbox to use that widget's checked state (preview only)."
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "locale"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "set_locale" },
            "locale": {
              "type": "string",
              "description": "Locale id from strings.res (e.g. en, de). Switches active language and refreshes localized widget text."
            }
          }
        }
      ]
    },
    "eventDef": {
      "type": "object",
      "required": ["trigger", "actions"],
      "additionalProperties": false,
      "properties": {
        "trigger": {
          "type": "string",
          "enum": ["clicked", "long_pressed", "value_changed"],
          "description": "LVGL event that fires this handler"
        },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/definitions/action" },
          "description": "May be empty; at least one action is typical"
        }
      }
    },
    "baseComponent": {
      "type": "object",
      "required": ["id", "type", "x", "y", "width", "height"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string" },
        "x": { "type": "integer" },
        "y": { "type": "integer" },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "hidden": { "type": "boolean" },
        "scrollX": { "type": "boolean" },
        "scrollY": { "type": "boolean" },
        "flexGrow": { "type": "integer", "minimum": 0 },
        "gridCol": { "type": "integer", "minimum": 0 },
        "gridRow": { "type": "integer", "minimum": 0 },
        "gridColSpan": { "type": "integer", "minimum": 1 },
        "gridRowSpan": { "type": "integer", "minimum": 1 },
        "gridCellXAlign": { "type": "string", "enum": ["start", "end", "center", "stretch"] },
        "gridCellYAlign": { "type": "string", "enum": ["start", "end", "center", "stretch"] },
        "styles": { "$ref": "#/definitions/styleProps" },
        "events": {
          "type": "array",
          "items": { "$ref": "#/definitions/eventDef" }
        }
      }
    },
    "component": {
      "oneOf": [
        {
          "allOf": [{ "$ref": "#/definitions/baseComponent" }],
          "properties": {
            "type": { "const": "label" },
            "text": { "type": "string" },
            "longMode": { "type": "string", "enum": ["wrap", "dot", "scroll", "clip"] }
          },
          "required": ["text"]
        },
        {
          "allOf": [{ "$ref": "#/definitions/baseComponent" }],
          "properties": {
            "type": { "const": "button" },
            "label": { "type": "string" }
          }
        },
        {
          "allOf": [{ "$ref": "#/definitions/baseComponent" }],
          "properties": {
            "type": { "const": "image" },
            "src": { "type": "string" }
          },
          "required": ["src"]
        },
        {
          "allOf": [{ "$ref": "#/definitions/baseComponent" }],
          "properties": {
            "type": { "const": "slider" },
            "min": { "type": "number" },
            "max": { "type": "number" },
            "value": { "type": "number" }
          },
          "required": ["min", "max", "value"]
        },
        {
          "allOf": [{ "$ref": "#/definitions/baseComponent" }],
          "properties": {
            "type": { "const": "switch" },
            "checked": { "type": "boolean" }
          },
          "required": ["checked"]
        },
        {
          "allOf": [{ "$ref": "#/definitions/baseComponent" }],
          "properties": {
            "type": { "const": "bar" },
            "min": { "type": "number" },
            "max": { "type": "number" },
            "value": { "type": "number" },
            "mode": { "type": "string", "enum": ["normal", "symmetrical", "range"] }
          },
          "required": ["min", "max", "value"]
        },
        {
          "allOf": [{ "$ref": "#/definitions/baseComponent" }],
          "properties": {
            "type": { "const": "spinner" },
            "speed": { "type": "integer" },
            "arcLength": { "type": "integer" }
          }
        },
        {
          "allOf": [{ "$ref": "#/definitions/baseComponent" }],
          "properties": {
            "type": { "const": "arc" },
            "min": { "type": "number" },
            "max": { "type": "number" },
            "value": { "type": "number" },
            "startAngle": { "type": "integer" },
            "endAngle": { "type": "integer" },
            "mode": { "type": "string", "enum": ["normal", "reverse", "symmetrical"] }
          },
          "required": ["min", "max", "value"]
        },
        {
          "allOf": [{ "$ref": "#/definitions/baseComponent" }],
          "properties": {
            "type": { "const": "checkbox" },
            "text": { "type": "string" },
            "checked": { "type": "boolean" }
          },
          "required": ["checked"]
        },
        {
          "allOf": [{ "$ref": "#/definitions/baseComponent" }],
          "properties": {
            "type": { "const": "dropdown" },
            "options": { "type": "array", "items": { "type": "string" } },
            "selectedIndex": { "type": "integer", "minimum": 0 }
          },
          "required": ["options", "selectedIndex"]
        },
        {
          "allOf": [{ "$ref": "#/definitions/baseComponent" }],
          "properties": {
            "type": { "const": "roller" },
            "options": { "type": "array", "items": { "type": "string" } },
            "selectedIndex": { "type": "integer", "minimum": 0 },
            "mode": { "type": "string", "enum": ["normal", "infinite"] }
          },
          "required": ["options", "selectedIndex"]
        },
        {
          "allOf": [{ "$ref": "#/definitions/baseComponent" }],
          "properties": {
            "type": { "const": "textarea" },
            "text": { "type": "string" },
            "placeholder": { "type": "string" },
            "oneLine": { "type": "boolean" }
          }
        },
        {
          "allOf": [{ "$ref": "#/definitions/baseComponent" }],
          "properties": {
