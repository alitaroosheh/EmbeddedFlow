{
  "version": "1.0",
  "project": {
    "name": "traffic",
    "lvglVersion": "8.4.0",
    "lvglInclude": "lvgl.h",
    "outputPath": "main/ui"
  },
  "display": {
    "width": 800,
    "height": 480,
    "bitDepth": 16,
    "colorFormat": "RGB565",
    "orientation": "landscape",
    "direction": "ltr",
    "dpi": 100,
    "round": false
  },
  "theme": {
    "dark": false,
    "primaryColor": "#49c7d0",
    "secondaryColor": "#5b5f71"
  },
  "pages": [
    {
      "id": "page_main",
      "name": "Main",
      "components": [
        {
          "id": "lbl_hello",
          "type": "label",
          "x": 10,
          "y": 10,
          "width": 200,
          "height": 30,
          "text": "Hello, EmbeddedFlow!",
          "animations": [
            {
              "property": "x",
              "from": -120,
              "to": 10,
              "duration": 900,
              "easing": "ease_out"
            }
          ]
        },
        {
          "id": "ta_1",
          "x": 204,
          "y": 12,
          "width": 160,
          "height": 72,
          "type": "textarea",
          "text": ""
        },
        {
          "id": "btn_1",
          "x": 671,
          "y": 410,
          "width": 88,
          "height": 36,
          "type": "button",
          "label": "Settings",
          "hidden": false,
          "events": [
            {
              "trigger": "clicked",
              "actions": [
                {
                  "type": "navigate",
                  "target": "page_settings",
                  "anim": "move_left"
                }
              ]
            }
          ]
        },
        {
          "id": "lbl_1",
          "x": 149,
          "y": 209,
          "width": 120,
          "height": 28,
          "type": "label",
          "text": "Label"
        },
        {
          "id": "chk_1",
          "x": 491,
          "y": 58,
          "width": 140,
          "height": 28,
          "type": "checkbox",
          "text": "Check",
          "checked": true,
          "hidden": false,
          "events": []
        },
        {
          "id": "card1_1",
          "type": "container",
          "x": 39,
          "y": 320,
          "width": 299,
          "height": 110,
          "layout": "none",
          "hidden": false,
          "children": [
            {
              "id": "card1_2",
              "x": 10,
              "y": 17,
              "width": 52,
              "height": 28,
              "type": "switch",
              "checked": false
            },
            {
              "id": "card1_3",
              "x": 25,
              "y": 54,
              "width": 140,
              "height": 36,
              "type": "dropdown",
              "options": [
                "One",
                "Two",
                "Three"
              ],
              "selectedIndex": 0
            },
            {
              "id": "card1_4",
              "x": 145,
              "y": 80,
              "width": 140,
              "height": 24,
              "type": "slider",
              "min": 0,
              "max": 100,
              "value": 50
            }
          ]
        },
        {
          "id": "card1_5",
          "type": "container",
          "x": 374,
          "y": 110,
          "width": 299,
          "height": 110,
          "layout": "none",
          "hidden": false,
          "children": [
            {
              "id": "card1_6",
              "x": -56,
              "y": -27,
              "width": 52,
              "height": 28,
              "type": "switch",
              "checked": false
            },
            {
              "id": "card1_7",
              "x": 90,
              "y": 2,
              "width": 140,
              "height": 36,
              "type": "dropdown",
              "options": [
                "One",
                "Two",
                "Three"
              ],
              "selectedIndex": 0
            },
            {
              "id": "card1_8",
              "x": 145,
              "y": 80,
              "width": 140,
              "height": 24,
              "type": "slider",
              "min": 0,
              "max": 100,
              "value": 50
            }
          ],
          "animations": [
            {
              "property": "x",
              "easing": "ease_out",
              "from": 0,
              "to": 80,
              "duration": 700
            }
          ],
          "events": [],
          "flexFlow": "row_wrap"
        },
        {
          "id": "img_1",
          "x": 349,
          "y": 353,
          "width": 48,
          "height": 48,
          "type": "image",
          "src": "logo",
          "hidden": false,
          "events": [],
          "animations": []
        },
        {
          "id": "img_2",
          "x": 531,
          "y": 282,
          "width": 48,
          "height": 48,
          "type": "image",
          "src": "logo",
          "hidden": false,
          "events": []
        },
        {
          "id": "knob_1",
          "x": 108,
          "y": 100,
          "width": 80,
          "height": 80,
          "type": "knob",
          "min": 0,
          "max": 100,
          "value": 50,
          "startAngle": 135,
          "endAngle": 45
        },
        {
          "id": "arc_1",
          "x": 284,
          "y": 124,
          "width": 80,
          "height": 80,
          "type": "arc",
          "min": 0,
