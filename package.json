{
  "name": "embeddedflow",
  "displayName": "EmbeddedFlow",
  "description": "LVGL UI preview for .embf project files — live canvas rendering via WebAssembly",
  "version": "0.1.0",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "lvgl",
    "embedded",
    "ui",
    "preview",
    "wasm"
  ],
  "activationEvents": [
    "onLanguage:embf",
    "workspaceContains:**/*.embf",
    "onCommand:embeddedflow.openPreview",
    "onCommand:embeddedflow.newProject",
    "onCommand:embeddedflow.generateCode",
    "onCommand:embeddedflow.showOutput"
  ],
  "main": "./out/extension.js",
  "icon": "media/erminity-mark.png",
  "contributes": {
    "languages": [
      {
        "id": "embf",
        "aliases": [
          "EmbeddedFlow Project",
          "embf"
        ],
        "extensions": [
          ".embf"
        ],
        "icon": {
          "light": "./media/erminity-mark.png",
          "dark": "./media/erminity-mark.png"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "embeddedflow.openPreview",
        "title": "EmbeddedFlow: Open UI Preview",
        "icon": "$(preview)"
      },
      {
        "command": "embeddedflow.newProject",
        "title": "EmbeddedFlow: New Project"
      },
      {
        "command": "embeddedflow.generateCode",
        "title": "EmbeddedFlow: Generate C Code",
        "icon": "$(file-code)"
      },
      {
        "command": "embeddedflow.showOutput",
        "title": "EmbeddedFlow: Show Output Log",
        "icon": "$(output)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "embeddedflow.openPreview",
          "when": "resourceExtname == .embf",
          "group": "navigation"
        },
        {
          "command": "embeddedflow.generateCode",
          "when": "resourceExtname == .embf",
          "group": "navigation"
        },
        {
          "command": "embeddedflow.showOutput",
          "when": "resourceExtname == .embf",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "embeddedflow.openPreview",
          "when": "resourceExtname == .embf",
          "group": "embeddedflow"
        },
        {
          "command": "embeddedflow.generateCode",
          "when": "resourceExtname == .embf",
          "group": "embeddedflow"
        },
        {
          "command": "embeddedflow.showOutput",
          "when": "resourceExtname == .embf",
          "group": "embeddedflow"
        }
      ]
    },
    "jsonValidation": [
      {
        "fileMatch": "*.embf",
        "url": "./src/schema/embf.schema.json"
      }
    ],
    "configuration": {
      "title": "EmbeddedFlow",
      "properties": {
        "embeddedflow.defaultLvglVersion": {
          "type": "string",
          "default": "9.5.0",
          "enum": [
            "8.4.0",
            "9.2.2",
            "9.3.0",
            "9.4.0",
            "9.5.0"
          ],
          "description": "Default LVGL version for new projects"
        },
        "embeddedflow.autoOpenPreview": {
          "type": "boolean",
          "default": true,
          "description": "When true, opening a .embf file automatically opens the UI preview beside the editor."
        },
        "embeddedflow.outputDirectory": {
          "type": "string",
          "default": "",
          "description": "Default output folder when project.outputPath is not set in the .embf JSON. Relative to the .embf file’s directory, or absolute. Leave empty to use ui_output next to the .embf file."
        },
        "embeddedflow.liveGenerateOnSave": {
          "type": "boolean",
          "default": false,
          "description": "When true, saving a .embf file regenerates C code after a short delay. Overwrites output files without confirmation. Skipped if the project has parse or semantic errors."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "vitest": "^2.1.9"
  }
}
